# Copy this file to /opt/miniapp/.env on the VPS and set chmod 600.

POSTGRES_DB=app
POSTGRES_USER=miniapp
POSTGRES_PASSWORD=replace-with-a-long-database-password
DATABASE_URL=postgresql+asyncpg://miniapp:replace-with-url-encoded-password@db:5432/app

MINIO_ROOT_USER=miniapp-storage
MINIO_ROOT_PASSWORD=replace-with-a-long-minio-password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=miniapp-storage
MINIO_SECRET_KEY=replace-with-a-long-minio-password
MINIO_BUCKET=product-photos
MINIO_SECURE=false
MINIO_PUBLIC_URL=/storage

TELEGRAM_BOT_TOKEN=123456:replace-with-real-bot-token
JWT_SECRET=replace-with-at-least-32-random-bytes
ADMIN_TELEGRAM_IDS=123456789

CORS_ORIGINS=https://miniapp.example.com
COOKIE_SECURE=true
